# FastAPI server only. Do not commit real secrets.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
# Optional: needed only if FastAPI verifies JWT locally instead of calling Supabase Auth.
SUPABASE_JWT_SECRET=
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://greeneatgo.vercel.app
# Public URL used by the mobile WebView checkout redirect. Include /v1.
PUBLIC_API_BASE_URL=https://greeneatgo-api.onrender.com/v1
# Admin origin used to construct company invitation links.
ADMIN_APP_URL=https://greeneatgo.vercel.app
# Server-only SendGrid credentials. Never use a VITE_ prefix or commit a real key.
SENDGRID_API_KEY=
# Must exactly match a SendGrid Single Sender or an address under an authenticated domain.
INVITE_EMAIL_FROM=GreenEatGo <your-verified-sender@example.com>
# Optional. If unset, voucher APIs expose only the first active merchant.
PILOT_MERCHANT_ID=
# Toss Payments keys. test_gck/test_gsk enables the payment widget.
# Existing test_ck/test_sk keys use the standard card payment window fallback.
TOSS_CLIENT_KEY=test_gck_...
TOSS_SECRET_KEY=test_gsk_...
# Firebase Admin service account. Set exactly one on the server; never expose it to web/mobile clients.
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=
